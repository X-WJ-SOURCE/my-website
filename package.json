{
  "name": "my-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/concurrently/dist/bin/concurrently.js \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "node ./node_modules/tsx/dist/cli.mjs watch server/main.ts",
    "client:dev": "node ./node_modules/vite/bin/vite.js",
    "seed": "node ./node_modules/tsx/dist/cli.mjs server/seed.ts",
    "build": "vite build",
    "start": "node ./node_modules/tsx/dist/cli.mjs server/main.ts",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@libsql/client": "^0.17.4",
    "@tailwindcss/vite": "^4.3.3",
    "bcryptjs": "^2.4.3",
    "hono": "^4.6.14",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.19.2",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
